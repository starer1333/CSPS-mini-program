.cart-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0,0,0,0.5);
}

.popup-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 30rpx 30rpx 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.header {
  padding: 30rpx;
  font-size: 36rpx;
  font-weight: bold;
  border-bottom: 2rpx solid #eee;
}

.cart-list {
  flex: 1;
  padding: 20rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.cart-item:last-child {
  border-bottom: none;
}

.item-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.item-info {
  flex: 2;
  margin-right: 20rpx;
}

.item-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.item-specs {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.item-price {
  width: 120rpx;
  font-size: 28rpx;
  color: #ff3b30;
  font-weight: bold;
  text-align: right;
  margin-right: 20rpx;
}

.item-quantity {
  display: flex;
  align-items: center;
  width: 140rpx;
  justify-content: space-between;
}

.quantity-btn {
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 36rpx;
  color: #333;
}

.quantity-num {
  width: 50rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
}

.delete-btn {
  font-size: 24rpx;
  color: #999;
  margin-left: 20rpx;
}

.footer {
  padding: 30rpx;
  border-top: 2rpx solid #eee;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.total {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff9f1c;
}

.settle-btn {
  background-color: #ff9f1c;
  color: #fff;
  width: 200rpx;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 35rpx;
  font-size: 28rpx;
  margin: 0;
  padding: 0;
  border: none;
}

.settle-btn::after {
  border: none;
}