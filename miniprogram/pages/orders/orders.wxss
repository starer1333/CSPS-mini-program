.orders {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.order-id {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.order-status {
  font-size: 26rpx;
  padding: 4rpx 20rpx;
  border-radius: 30rpx;
  font-weight: 500;
}

.order-status.order-placed {
  background-color: #52c41a20;  /* 浅绿色背景 */
  color: #52c41a;                /* 绿色文字 */
}

.order-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

/* 商品明细 */
.order-items {
  margin-bottom: 20rpx;
}

.order-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.delivery-item {
  color: #666;
}

.delivery-item .item-total {
  color: #ff9f1c;        /* 橙色，与商品总价区分 */
}

.item-info {
  flex: 2;
}

.item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.item-specs {
  font-size: 22rpx;
  color: #999;
  display: block;
}

.item-detail {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 20rpx;
}

.item-quantity {
  font-size: 26rpx;
  color: #666;
  min-width: 60rpx;
  text-align: right;
}

.item-price {
  font-size: 26rpx;
  color: #666;
  min-width: 80rpx;
  text-align: right;
}

.item-total {
  font-size: 28rpx;
  color: #ff9f1c;        /* 橙色 */
  font-weight: bold;
  min-width: 100rpx;
  text-align: right;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
}

.order-total {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff9f1c;        /* 橙色 */
}

.empty {
  text-align: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 32rpx;
}