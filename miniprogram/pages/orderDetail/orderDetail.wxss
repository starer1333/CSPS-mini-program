.order-detail {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.detail-header {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status {
  font-size: 32rpx;
  font-weight: bold;
  padding: 4rpx 20rpx;
  border-radius: 40rpx;
  background-color: #f0f0f0;
  color: #666;
}

.status.paid {
  background-color: #52c41a20;
  color: #52c41a;
}

.status.completed {
  background-color: #52c41a20;
  color: #52c41a;
}

.status.cancelled {
  background-color: #f5222d20;
  color: #f5222d;
}

.order-id {
  font-size: 28rpx;
  color: #666;
}

.info-card, .items-card, .total-card, .payment-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}

.info-row {
  display: flex;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

.label {
  width: 160rpx;
  color: #999;
}

.value {
  flex: 1;
  color: #333;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.order-item {
  display: flex;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.order-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.item-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.item-specs {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 10rpx;
}

.item-price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.item-quantity {
  font-size: 26rpx;
  color: #666;
}

.item-price {
  font-size: 28rpx;
  color: #ff3b30;
  font-weight: bold;
}

.item-unit {
  font-size: 22rpx;
  color: #999;
}

.total-row {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.total-row.final {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff3b30;
  border-top: 2rpx solid #f0f0f0;
  padding-top: 20rpx;
  margin-top: 10rpx;
}

.free {
  color: #52c41a;
  font-weight: 500;
}

.payment-card {
  display: flex;
  align-items: center;
  font-size: 28rpx;
}

.reorder-btn {
  background-color: #ff9f1c;
  color: #fff;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  width: 100%;
  margin-top: 30rpx;
  border: none;
}

.reorder-btn::after {
  border: none;
}