.checkout {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
  color: #333;
}

/* 商品列表 */
.cart-item {
  display: flex;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.cart-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.item-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.item-info {
  flex: 1;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.item-price {
  font-size: 30rpx;
  color: #ff6b6b;
  font-weight: bold;
}

.item-specs {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-quantity {
  font-size: 26rpx;
  color: #666;
}

.item-unit-price {
  font-size: 24rpx;
  color: #999;
}

/* 行 */
.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.coupon-info {
  display: flex;
  align-items: center;
}

.coupon-name {
  color: #ff6b6b;
  margin-right: 10rpx;
}

.placeholder {
  color: #999;
  margin-right: 10rpx;
}

.arrow {
  color: #999;
  font-size: 32rpx;
}

.total-section {
  background-color: #fff8f8;
}

.total {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b6b;
}

/* 备注 */
.remark-input {
  background-color: #f5f5f5;
  padding: 24rpx 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 支付方式 */
.payment-options {
  display: flex;
  gap: 20rpx;
}

.payment-option {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.payment-option.active {
  background-color: #ff6b6b;
  color: #fff;
}

/* 提交按钮 */
.submit-btn {
  position: fixed;
  bottom: 30rpx;
  left: 30rpx;
  right: 30rpx;
  width: auto;
  background-color: #ff6b6b;
  color: #fff;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 20rpx rgba(255,107,107,0.3);
  z-index: 100;
}

.submit-btn::after {
  border: none;
}
.meal-display {
  font-size: 32rpx;
  color: #333;
  padding: 20rpx 0;
}
.address-input {
  background-color: #f5f5f5;
  padding: 24rpx 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  min-height: 80rpx;
}
.time-picker {
  background-color: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  text-align: left;
}
.table-display {
  font-size: 32rpx;
  color: #ff6b6b;
  font-weight: bold;
  padding: 20rpx 0;
}
.free-delivery {
  color: #ff9f1c;
  font-weight: 500;
}
.time-input {
  background-color: #f5f5f5;
  padding: 24rpx 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  min-height: 80rpx;
}