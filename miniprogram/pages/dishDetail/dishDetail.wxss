.dish-detail {
  padding-bottom: 120rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.main-img {
  width: 100%;
  height: 500rpx;
}

.content {
  padding: 30rpx;
  background-color: #fff;
  border-radius: 30rpx 30rpx 0 0;
  margin-top: -30rpx;
}

.name {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  display: block;
  margin-bottom: 40rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.spec-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.spec-group {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.spec-item {
  padding: 16rpx 30rpx;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  border: 2rpx solid transparent;
}

.spec-item.active {
  background-color: #ff9f1c;
  color: #fff;
}

.spec-price {
  font-size: 24rpx;
  margin-left: 8rpx;
  color: #ff9f1c;
}

.spec-item.active .spec-price {
  color: #fff;
}

.quantity-section {
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.quantity-control {
  display: flex;
  align-items: center;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  overflow: hidden;
}

.quantity-btn {
  width: 70rpx;
  height: 70rpx;
  line-height: 70rpx;
  text-align: center;
  background-color: #f5f5f5;
  font-size: 40rpx;
  color: #333;
}

.quantity-num {
  width: 100rpx;
  height: 70rpx;
  line-height: 70rpx;
  text-align: center;
  font-size: 32rpx;
  border-left: 2rpx solid #ddd;
  border-right: 2rpx solid #ddd;
}

.price-info {
  background-color: #f9f9f9;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.price-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.price-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #666;
}

.member-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff3b30;
}

.normal-price {
  font-size: 32rpx;
  color: #ff3b30;
  text-decoration: line-through;
  opacity: 0.7;
}

.add-cart-btn {
  background-color: #ff9f1c;
  color: #fff;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin: 0 30rpx 30rpx;
  width: auto;
  box-shadow: 0 4rpx 20rpx rgba(255,159,28,0.3);
}

.add-cart-btn::after {
  border: none;
}