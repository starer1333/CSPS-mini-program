.coupons {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.tabs {
  display: flex;
  background-color: #fff;
  border-bottom: 2rpx solid #eee;
}

.tab {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
}

.tab.active {
  color: #ff9f1c;
  border-bottom: 4rpx solid #ff9f1c;
}

.coupon-list {
  flex: 1;
  padding: 20rpx;
}

.coupon-card {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-left: 8rpx solid #ff9f1c;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.coupon-card.used {
  opacity: 0.6;
  border-left-color: #999;
}

.coupon-card.expired {
  opacity: 0.4;
  border-left-color: #f5222d;
}

.coupon-left {
  flex: 2;
}

.coupon-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.coupon-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}

.coupon-source {
  font-size: 22rpx;
  color: #999;
}

.coupon-right {
  flex: 1;
  text-align: right;
}

.coupon-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff3b30;
  display: block;
  margin-bottom: 8rpx;
}

.coupon-expire {
  font-size: 22rpx;
  color: #999;
}

.empty {
  text-align: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 32rpx;
}