.my {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 登录状态卡片 */
.user-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 30rpx;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.badge-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
}

.member-badge {
  background-color: #ff9f1c;
  color: #fff;
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 30rpx;
}

.balance, .points {
  font-size: 26rpx;
  color: #666;
}

.coupon-count {
  font-size: 26rpx;
  color: #ff3b30;
  font-weight: 500;
  background-color: #fff0f0;
  padding: 6rpx 20rpx;
  border-radius: 40rpx;
  white-space: nowrap;
}

/* 未登录卡片 */
.login-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  margin-bottom: 20rpx;
}

.login-text {
  font-size: 32rpx;
  color: #ff9f1c;
  font-weight: 500;
}

/* 功能入口网格 */
.menu-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx 20rpx;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 16rpx;
}

.menu-item text {
  font-size: 26rpx;
  color: #333;
}