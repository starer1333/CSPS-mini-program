<view class="my">
  <!-- 顶部信息卡（登录状态） -->
  <view class="user-card" wx:if="{{userInfo}}">
    <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
    <view class="user-info">
      <text class="nickname">{{userInfo.nickName}}</text>
      <view class="badge-row">
        <text class="member-badge" wx:if="{{isMember}}">会员</text>
        <text class="member-badge" wx:else>普通顾客</text>
        <text class="balance">余额 ¥{{balance}}</text>
        <text class="points">积分 {{points}}</text>
      </view>
    </view>
    <text class="coupon-count">优惠券 {{couponCount}} 张</text>
    <view class="menu-item" bindtap="goToCoupons">
  <image class="menu-icon" src="/images/icons/coupon.png"></image>
  <text>优惠券</text>
</view>
  </view>
  
  <!-- 未登录状态 -->
  <view class="login-card" wx:else bindtap="login">
    <image class="avatar-placeholder" src="/images/default-avatar.png"></image>
    <text class="login-text">点击登录</text>
  </view>

  <!-- 功能入口网格 -->
  <view class="menu-grid">
    <view class="menu-item" bindtap="goToRecharge">
      <image class="menu-icon" src="/images/icons/recharge.png"></image>
      <text>在线充值</text>
    </view>
    <view class="menu-item" bindtap="goToInfo">
      <image class="menu-icon" src="/images/icons/info.png"></image>
      <text>我的信息</text>
    </view>
    <view class="menu-item" bindtap="goToTerms">
      <image class="menu-icon" src="/images/icons/terms.png"></image>
      <text>会员条款</text>
    </view>
    <view class="menu-item" bindtap="goToCoupons">
      <image class="menu-icon" src="/images/icons/coupon.png"></image>
      <text>优惠券</text>
    </view>
    <view class="menu-item" bindtap="goToExchange">
      <image class="menu-icon" src="/images/icons/exchange.png"></image>
      <text>充值兑换</text>
    </view>
    <!-- 预留更多入口 -->
  </view>
</view>